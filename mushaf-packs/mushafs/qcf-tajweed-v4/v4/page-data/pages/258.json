 ۖ وَمَا كَانَ لِىَ عَلَيْكُم مِّن سُلْطَـٰنٍ إِلَّآ أَن دَعَوْتُكُمْ فَٱسْتَجَبْتُمْ لِى ۖ فَلَا تَلُومُونِى وَلُومُوٓا۟ أَنفُسَكُم ۖ مَّآ أَنَا۠ بِمُصْرِخِكُمْ وَمَآ أَنتُم بِمُصْرِخِىَّ ۖ إِنِّى كَفَرْتُ بِمَآ أَشْرَكْتُمُونِ مِن قَبْلُ ۗ إِنَّ ٱلظَّـٰلِمِينَ لَهُمْ عَذَابٌ أَلِيمٌ","textIndopak":"وَقَالَ الشَّيۡطٰنُ لَـمَّا قُضِىَ الۡاَمۡرُ اِنَّ اللّٰهَ وَعَدَكُمۡ وَعۡدَ الۡحَـقِّ وَوَعَدْتُّكُمۡ فَاَخۡلَفۡتُكُمۡ​ؕ وَمَا كَانَ لِىَ عَلَيۡكُمۡ مِّنۡ سُلۡطٰنٍ اِلَّاۤ اَنۡ دَعَوۡتُكُمۡ فَاسۡتَجَبۡتُمۡ لِىۡ​ ۚ فَلَا تَلُوۡمُوۡنِىۡ وَلُوۡمُوۡۤا اَنۡفُسَكُمۡ​ ؕ مَاۤ اَنَا بِمُصۡرِخِكُمۡ وَمَاۤ اَنۡتُمۡ بِمُصۡرِخِىَّ​ ؕ اِنِّىۡ كَفَرۡتُ بِمَاۤ اَشۡرَكۡتُمُوۡنِ مِنۡ قَبۡلُ​ ؕ اِنَّ الظّٰلِمِيۡنَ لَهُمۡ عَذَابٌ اَ لِيۡمٌ‏","textUthmaniTajweed":"وَقَالَ <tajweed class=ham_wasl>ٱ</tajweed><tajweed class=laam_shamsiyah>ل</tajweed>شَّيْطَ<tajweed class=madda_normal>ـٰ</tajweed>نُ لَ<tajweed class=ghunnah>مّ</tajweed>َا قُضِىَ <tajweed class=ham_wasl>ٱ</tajweed>لْأَمْرُ إِ<tajweed class=ghunnah>نّ</tajweed>َ <tajweed class=ham_wasl>ٱ</tajweed>للَّهَ وَعَدَكُمْ وَعْدَ <tajweed class=ham_wasl>ٱ</tajweed>لْحَقِّ وَوَعَ<tajweed class=idgham_mutajanisayn>د</tajweed>تُّكُمْ فَأَخْلَفْتُكُمْ‌ۖ وَمَا كَانَ لِىَ عَلَيْك<tajweed class=idgham_shafawi>ُم م</tajweed>ِّ<tajweed class=ikhafa>ن س</tajweed>ُلْطَ<tajweed class=madda_normal>ـٰ</tajweed>نٍ إِلّ<tajweed class=madda_obligatory>َآ</tajweed> أَ<tajweed class=ikhafa>ن د</tajweed>َعَوْتُكُمْ فَ<tajweed class=ham_wasl>ٱ</tajweed>سْتَجَ<tajweed class=qalaqah>بْ</tajweed>تُمْ لِى‌ۖ فَلَا تَلُومُونِى وَلُوم<tajweed class=madda_obligatory>ُوٓ</tajweed><tajweed class=slnt>اْ</tajweed> أَ<tajweed class=ikhafa>نف</tajweed>ُسَك<tajweed class=idgham_shafawi>ُم‌ۖ م</tajweed>ّ<tajweed class=madda_obligatory>َآ</tajweed> أَنَا۟ بِمُصْرِخِكُمْ وَم<tajweed class=madda_obligatory>َآ</tajweed> أَ<tajweed class=ikhafa>نت</tajweed><tajweed class=ikhafa_shafawi>ُم ب</tajweed>ِمُصْرِخِىَّ‌ۖ إِ<tajweed class=ghunnah>نّ</tajweed>ِى كَفَرْتُ بِم<tajw
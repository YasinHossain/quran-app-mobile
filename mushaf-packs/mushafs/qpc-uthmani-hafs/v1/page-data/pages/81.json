رِكُم مِّن نِّسَآئِكُمُ ٱلَّـٰتِى دَخَلْتُم بِهِنَّ فَإِن لَّمْ تَكُونُوا۟ دَخَلْتُم بِهِنَّ فَلَا جُنَاحَ عَلَيْكُمْ وَحَلَـٰٓئِلُ أَبْنَآئِكُمُ ٱلَّذِينَ مِنْ أَصْلَـٰبِكُمْ وَأَن تَجْمَعُوا۟ بَيْنَ ٱلْأُخْتَيْنِ إِلَّا مَا قَدْ سَلَفَ ۗ إِنَّ ٱللَّهَ كَانَ غَفُورًا رَّحِيمًا","textIndopak":"حُرِّمَتۡ عَلَيۡكُمۡ اُمَّهٰتُكُمۡ وَبَنٰتُكُمۡ وَاَخَوٰتُكُمۡ وَعَمّٰتُكُمۡ وَخٰلٰتُكُمۡ وَبَنٰتُ الۡاٰخِ وَبَنٰتُ الۡاُخۡتِ وَاُمَّهٰتُكُمُ الّٰتِىۡۤ اَرۡضَعۡنَكُمۡ وَاَخَوٰتُكُمۡ مِّنَ الرَّضَاعَةِ وَ اُمَّهٰتُ نِسَآٮِٕكُمۡ وَرَبَآٮِٕبُكُمُ الّٰتِىۡ فِىۡ حُجُوۡرِكُمۡ مِّنۡ نِّسَآٮِٕكُمُ الّٰتِىۡ دَخَلۡتُمۡ بِهِنَّ فَاِنۡ لَّمۡ تَكُوۡنُوۡا دَخَلۡتُمۡ بِهِنَّ فَلَا جُنَاحَ عَلَيۡكُمۡ وَحَلَاۤٮِٕلُ اَبۡنَآٮِٕكُمُ الَّذِيۡنَ مِنۡ اَصۡلَابِكُمۡۙ وَاَنۡ تَجۡمَعُوۡا بَيۡنَ الۡاُخۡتَيۡنِ اِلَّا مَا قَدۡ سَلَفَ​ؕ اِنَّ اللّٰهَ كَانَ غَفُوۡرًا رَّحِيۡمًا ۙ‏","textUthmaniTajweed":"حُرِّمَتْ عَلَيْكُمْ أُ<tajweed class=ghunnah>مّ</tajweed>َهَ<tajweed class=madda_normal>ـٰ</tajweed>تُكُمْ وَبَنَاتُكُمْ وَأَخَو<tajweed class=madda_normal>َٲ</tajweed>تُكُمْ وَعَ<tajweed class=ghunnah>مّ</tajweed>َ<tajweed class=madda_normal>ـٰ</tajweed>تُكُمْ وَخَ<tajweed class=madda_normal>ـٰ</tajweed>لَ<tajweed class=madda_normal>ـٰ</tajweed>تُكُمْ وَبَنَاتُ <tajweed class=ham_wasl>ٱ</tajweed>لْأَخِ وَبَنَاتُ <tajweed class=ham_wasl>ٱ</tajweed>لْأُخْتِ وَأُ<tajweed class=ghunnah>مّ</tajweed>َهَ<tajweed class=madda_normal>ـٰ</tajweed>تُكُمُ <tajweed class=ham_wasl>ٱ</tajweed>لَّ<tajweed class=madda_normal>ـٰ</tajweed>ت<tajweed class=madda_obligatory>ِىٓ</tajweed> أَرْضَعْنَكُمْ وَأَخَو<tajweed class=madda_normal>َٲ</tajweed>تُك<tajweed class=idgham_shafawi>ُم م</tajweed>ِّنَ <tajweed class=ham_wasl>ٱ</tajweed><tajweed class=laam_shamsiyah>ل</tajweed>رَّضَ<tajweed class=madda_normal>ـٰ</tajweed>عَةِ وَأُ<tajweed class=ghunnah>مّ</tajweed>َهَ<tajweed class=madda_normal>ـٰ</tajweed>تُ نِس<tajweed class=madda_obligatory>َا</tajweed>ٓئِكُمْ وَرَبَ<tajweed class=madda_obligatory>ـٰٓ</tajweed>ئِبُكُمُ <t
{
  "expo": {
    "name": "quran-app-mobile",
    "slug": "quran-app-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "quranappmobile",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "UIBackgroundModes": [
          "audio"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ],
      "package": "com.anonymous.quranappmobile"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-audio",
      "expo-web-browser",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-status-bar",
      "expo-asset",
      "./plugins/withVerseSpotlightWidget"
    ],
    "extra": {
      "translationPackCatalogUrl": "https://yasinhossain.github.io/quran-app-mobile/translation-packs/catalog.json",
      "wordTranslationPackCatalogUrl": "https://yasinhossain.github.io/quran-app-mobile/word-translation-packs/catalog.json?v=2026-07-04",
      "tafsirPackCatalogUrl": "https://yasinhossain.github.io/quran-app-mobile/tafsir-packs/catalog.json",
      "mushafPackCatalogUrl": "https://yasinhossain.github.io/quran-app-mobile/mushaf-packs/catalog.json",
      "wordStudyPackCatalogUrl": "https://raw.githubusercontent.com/YasinHossain/quran-app-mobile/gh-pages/word-study-packs/catalog.json",
      "wordGrammarPackCatalogUrl": "https://raw.githubusercontent.com/YasinHossain/quran-app-mobile/gh-pages/word-grammar-packs/catalog.json",
      "wordReferencePackCatalogUrl": "https://raw.githubusercontent.com/YasinHossain/quran-app-mobile/gh-pages/word-reference-packs/catalog.json"
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/verse_spotlight_widget_background"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingTop="12dp"
    android:paddingEnd="12dp"
    android:paddingBottom="8dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="start|center_vertical"
        android:includeFontPadding="false"
        android:text="@string/verse_spotlight_preview_translation"
        android:textColor="@color/verse_spotlight_widget_text"
        android:textDirection="firstStrong"
        android:textSize="17sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layoutDirection="ltr"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:gravity="start|center_vertical"
            android:maxLines="1"
            android:text="@string/verse_spotlight_preview_metadata"
            android:textColor="@color/verse_spotlight_widget_accent"
            android:textSize="13sp"
            android:textStyle="bold" />

        <ImageButton
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:background="@drawable/verse_spotlight_shuffle_background"
            android:contentDescription="@string/verse_spotlight_shuffle"
            android:padding="9dp"
            android:src="@drawable/verse_spotlight_ic_shuffle"
            android:tint="@color/verse_spotlight_widget_shuffle_icon" />

        <ImageButton
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_marginStart="5dp"
            android:background="@drawable/verse_spotlight_control_background"
            android:contentDescription="@string/verse_spotlight_previous"
            android:padding="10dp"
            android:src="@drawable/verse_spotlight_ic_previous"
            android:tint="@color/verse_spotlight_widget_icon" />

        <ImageButton
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_marginStart="5dp"
            android:background="@drawable/verse_spotlight_control_background"
            android:contentDescription="@string/verse_spotlight_next"
            android:padding="10dp"
            android:src="@drawable/verse_spotlight_ic_next"
            android:tint="@color/verse_spotlight_widget_icon" />

    </LinearLayout>
</LinearLayout>
